{
    "name": "mapdeck",
    "version": "0.6.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "lint": "tsc --noEmit && eslint --max-warnings=0",
        "test": "vitest run",
        "test:watch": "vitest",
        "license-check": "license-checker-rseidelsohn --production --excludePrivatePackages --onlyAllow \"MIT;ISC;BSD-2-Clause;BSD-3-Clause;Apache-2.0;CC0-1.0;0BSD\" --excludePackages \"@mapbox/jsonlint-lines-primitives\" > /dev/null 2>&1"
    },
    "dependencies": {
        "@deck.gl/core": "^9.2.7",
        "@deck.gl/layers": "^9.2.7",
        "@deck.gl/mapbox": "^9.2.7",
        "@turf/area": "^7.3.5",
        "@turf/bbox": "^7.3.5",
        "@turf/bbox-polygon": "^7.3.5",
        "@turf/boolean-intersects": "^7.3.5",
        "@turf/distance": "^7.3.4",
        "copc": "^0.0.8",
        "laz-perf": "^0.0.7",
        "maplibre-gl": "^5.21.0",
        "mobx": "^6.15.0",
        "mobx-react-lite": "^4.1.1",
        "proj4": "^2.20.4",
        "rbush": "^4.0.1",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-grid-layout": "^2.2.2"
    },
    "devDependencies": {
        "@types/node": "^25.0.5",
        "@types/rbush": "^4.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@types/react-grid-layout": "^1.3.6",
        "@typescript-eslint/eslint-plugin": "^8.57.0",
        "@typescript-eslint/parser": "^8.0.0",
        "@vitejs/plugin-react": "^6.0.0",
        "eslint": "^9.14.0",
        "eslint-plugin-react": "^7.37.0",
        "eslint-plugin-react-hooks": "^7.0.0",
        "eslint-plugin-sonarjs": "^4.0.0",
        "license-checker-rseidelsohn": "^4.4.2",
        "typescript": "^5.2.0",
        "vite": "^8.0.0",
        "vitest": "^4.1.9"
    }
}
